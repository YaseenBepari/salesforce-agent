{
  "manifest_version": 3,
  "name": "Antigravity Salesforce Copilot",
  "version": "1.0.0",
  "description": "AI-Powered Salesforce Sidebar Assistant and intelligent developer companion.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*.force.com/*",
    "https://*.salesforce.com/*",
    "https://*.force-setup.com/*"
  ],
  "action": {
    "default_title": "Toggle Antigravity Salesforce Copilot"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.force.com/*",
        "https://*.salesforce.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
